{
  "name": "book-bridge-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:development": "vite build --mode development",
    "build:testing": "vite build --mode testing",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/**/*.{vue,js,jsx,cjs,mjs}",
    "check": "npm run lint && npm run format"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "vuex": "^4.1.0",
    "axios": "^1.7.9",
    "element-plus": "^2.8.5",
    "echarts": "^5.5.1",
    "vue-echarts": "^7.0.3",
    "crypto-js": "^4.2.0",
    "winston": "^3.14.2",
    "@logtail/browser": "^0.4.18",
    "web-vitals": "^3.6.0",
    "@sentry/browser": "^7.127.0",
    "file-saver": "^2.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.5",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.3.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1"
  }
}